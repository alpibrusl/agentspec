apiVersion: agent/v1
name: base-codex
version: 1.0.0
description: "Base Codex CLI agent — general-purpose development"
tags: [base, codex, openai, development]

model:
  capability: reasoning-high
  preferred:
    - openai/o3
    - openai/gpt-4o
  fallback: reasoning-mid

skills:
  - code-execution
  - file-read
  - file-write
  - git

tools:
  native:
    - bash

behavior:
  persona: senior-developer
  traits:
    - think-step-by-step
    - be-concise
    - self-review
  temperature: 0.2
  max_steps: 50
  on_error: retry

trust:
  filesystem: scoped
  scope: [./src, ./tests, ./docs]
  network: allowed
  exec: sandboxed

observability:
  trace: true
  step_limit: 50
