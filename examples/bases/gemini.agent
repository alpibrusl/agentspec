apiVersion: agent/v1
name: base-gemini
version: 1.0.0
description: "Base Gemini CLI agent — general-purpose development"
tags: [base, gemini, development]

model:
  capability: reasoning-high
  preferred:
    - gemini/gemini-2.5-pro
    - gemini/gemini-2.0-flash
  fallback: reasoning-mid

skills:
  - code-execution
  - file-read
  - file-write
  - git
  - web-search

tools:
  native:
    - bash

behavior:
  persona: senior-developer
  traits:
    - think-step-by-step
    - be-concise
    - self-review
  temperature: 0.2
  max_steps: 50
  on_error: retry

trust:
  filesystem: scoped
  scope: [./src, ./tests, ./docs]
  network: allowed
  exec: sandboxed

observability:
  trace: true
  step_limit: 50

extensions:
  x-gemini:
    grounding: true
