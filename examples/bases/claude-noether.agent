apiVersion: agent/v1
name: base-claude-noether
version: 1.0.0
description: "Claude agent with Noether verified composition skills"
tags: [base, claude, noether, composition]

base: ./claude.agent

merge:
  skills: append
  tools: append
  behavior: append
  trust: restrict

skills:
  - noether-compose
  - noether-run
  - noether-search
  - noether-serve

behavior:
  traits:
    - noether-first
    - noether-verify
  temperature: 0.1

trust:
  filesystem: scoped
  scope: [./src, ./tests, ./docs, ./compositions, ./stages]
  network: allowed
  exec: sandboxed
