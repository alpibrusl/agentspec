apiVersion: agent/v1
name: legal-researcher
version: 1.0.0
description: "Researcher specialised in legal sources"
tags: [research, legal, citations]

# Inherits from researcher — demonstrates merge semantics
base: ./researcher.agent

merge:
  skills: append
  tools: append
  behavior: override
  trust: restrict

# Adds legal-specific MCP tools on top of parent's
tools:
  mcp:
    - courtlistener
    - google-scholar

behavior:
  persona: precise-legal-researcher
  traits:
    - cite-everything
    - flag-uncertainty
    - never-guess
    - cite-jurisdiction
  temperature: 0.1

# Trust automatically restricted to parent's level
# (filesystem: none, network: allowed, exec: none)
